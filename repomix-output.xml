                    module_id=module_id,
                    title=lesson_spec["title"],
                    objectives=lesson_spec["objectives"],
                    content=lesson_spec["content"],
                    is_enriched=True,
                    auto_enriched=True,
                )
            )
        modules.append(
            ModuleOutline(
                id=module_id,
                title=spec["module_title"],

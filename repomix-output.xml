        cx="50"
        cy="10"
        r="5"
        fill="#fbbf24"
        animate={{ scale: thinking ? [1, 1.4, 1] : [1, 1.1, 1] }}
        transition={{ duration: thinking ? 0.6 : 2, repeat: Infinity, ease: 'easeInOut' }}

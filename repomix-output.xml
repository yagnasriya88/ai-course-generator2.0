  return (
    <motion.svg
      viewBox="0 0 100 100"
      className={className}
      animate={{ y: thinking ? [0, -4, 0] : [0, -2, 0] }}
      transition={{ duration: thinking ? 1.1 : 2.6, repeat: Infinity, ease: 'easeInOut' }}

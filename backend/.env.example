MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=learnify_ai
CORS_ORIGINS=http://localhost:5173

# Video discovery/notes and Hinglish TTS always use Gemini directly — required either way.
GEMINI_API_KEY=

# LLM_PROVIDER picks the model for course/lesson generation: "openai" (default) or "gemini".
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini

# Clerk (https://dashboard.clerk.com) handles authentication — same publishable
# key as the frontend's VITE_CLERK_PUBLISHABLE_KEY, plus the secret key for
# Backend API calls.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
